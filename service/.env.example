# ── PERSCOM API ──────────────────────────────────────────────────────────────
PERSCOM_API_URL=https://api.1stcavalry.org
PERSCOM_API_KEY=your-api-key-here

# Comma-separated PERSCOM status IDs whose personnel appear in squad.xml.
# From the API: statusId 1 = "Active Duty". Add others as needed (e.g. 1,2).
ACTIVE_STATUS_IDS=1

# Optional: restrict to specific unit IDs. Leave blank for the whole org.
# Example: FILTER_UNIT_IDS=8,12,15
FILTER_UNIT_IDS=

# ── SQUAD METADATA (written into squad.xml) ──────────────────────────────────
SQUAD_TAG=1CAV
SQUAD_NAME=1st Cavalry Division
SQUAD_EMAIL=admin@1stcavalry.org
SQUAD_WEB=https://1stcavalry.org
SQUAD_TITLE=1st Cavalry Division - Arma 3 MilSim

# Filename (no path, no extension) of the PAA logo in service/static/.
# Example: LOGO_FILENAME=1cav  →  serves /1cav.paa from static/1cav.paa
# Leave blank if you have no logo.
LOGO_FILENAME=

# ── SYNC SETTINGS ────────────────────────────────────────────────────────────
# How often to re-sync from PERSCOM, in seconds (default: 300 = 5 minutes)
SYNC_INTERVAL=300

# Secret used to authenticate POST /sync requests for manual out-of-band syncs
SYNC_KEY=change-me-to-a-random-secret
